{
  // ── ESP-IDF (ESP32 v6.0.1 Configuration) ──────────────────────────────
  "idf.espIdfPath": "C:\\esp\\v6.0.1\\esp-idf",
  "idf.pythonBinPath": "C:\\Espressif\\tools\\python\\v6.0.1\\venv\\Scripts\\python.exe",
  "idf.toolsPath": "C:\\Espressif\\tools",
  "idf.port": "COM5",
  "idf.flashBaudRate": "460800",
  "idf.buildPath": "${workspaceFolder}\\build",
  "idf.currentSetup": "C:\\esp\\v6.0.1\\esp-idf",

  // ── C/C++ IntelliSense (Xtensa GCC Compiler) ──────────────────────────
  "C_Cpp.intelliSenseEngine": "Tag Parser",
  "C_Cpp.default.compilerPath": "C:\\Espressif\\tools\\xtensa-esp-elf\\esp-15.2.0_20251204\\xtensa-esp-elf\\bin\\xtensa-esp32-elf-gcc.exe",
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/**",
    "C:\\esp\\v6.0.1\\esp-idf\\components/**",
    "C:\\Espressif\\tools\\xtensa-esp-elf\\esp-15.2.0_20251204\\xtensa-esp-elf\\include",
    "C:\\Espressif\\tools\\xtensa-esp-elf\\esp-15.2.0_20251204\\xtensa-esp-elf\\xtensa-esp-elf\\include"
  ],
  "C_Cpp.default.defines": [
    "ESP_PLATFORM",
    "IDF_VER=\\\"6.0.1\\\""
  ],
  "C_Cpp.default.cStandard": "c11",
  "C_Cpp.default.cppStandard": "c++17",
  "C_Cpp.default.compileCommands": "${workspaceFolder}\\build\\compile_commands.json",
  "C_Cpp.default.intelliSenseMode": "gcc-x64",

  // ── Editor (Code Style) ───────────────────────────────────────────────
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [80, 120],
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "ms-vscode.cpptools",
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // ── Copilot ──────────────────────────────────────────────────────────
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false
  },
  "github.copilot.editor.enableAutoCompletions": true,

  // ── Git ──────────────────────────────────────────────────────────────
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.rebaseWhenSync": true,

  // ── File associations ────────────────────────────────────────────────
  "files.associations": {
    "*.h": "c",
    "*.c": "c",
    "Kconfig": "plaintext",
    "sdkconfig*": "properties"
  },

  // ── Exclude clutter from explorer ───────────────────────────────────
  "files.exclude": {
    "build/": true,
    ".cache/": true,
    "**/*.pyc": true,
    "**/__pycache__": true
  },

  // ── CMake Configuration ──────────────────────────────────────────────
  "cmake.configureOnOpen": false,
  "cmake.generator": "Ninja"
}
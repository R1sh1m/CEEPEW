{
    // ── CEE-PEW Copilot Configuration ──────────────────────────────────
    // All Copilot features read from .github/copilot-instructions.md
    // Additional per-component instructions are in .github/instructions/

    "github.copilot.chat.codeGeneration.instructions": [
        { "file": ".github/copilot-instructions.md" },
        { "file": ".github/instructions/crypto.instructions.md" },
        { "file": ".github/instructions/ecc.instructions.md" },
        { "file": ".github/instructions/compress-tools.instructions.md" },
        { "file": ".github/instructions/hal.instructions.md" }
    ],

    "github.copilot.chat.reviewSelection.instructions": [
        { "file": ".github/copilot-instructions.md" }
    ],

    "github.copilot.chat.testGeneration.instructions": [
        { "file": ".github/copilot-instructions.md" }
    ],

    "github.copilot.chat.commitMessageGeneration.instructions": [
        {
            "text": "Format: M{milestone}: {component}: {description}. Example: M4: ecc_hamming: implement session-permuted (15,11) encode/decode"
        }
    ],

    // ── IDF Terminal (auto-activates environment) ───────────────────────
    "terminal.integrated.profiles.windows": {
        "IDF PowerShell": {
            "source": "PowerShell",
            "args": [
                "-NoExit",
                "-Command",
                "& 'C:\\Espressif\\tools\\Microsoft.v6.0.1.PowerShell_profile.ps1'"
            ]
        }
    },
    "terminal.integrated.defaultProfile.windows": "IDF PowerShell",

    // ── Editor — tuned for embedded C ──────────────────────────────────
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.rulers": [80, 100],
    "editor.formatOnSave": false,
    "editor.semanticHighlighting.enabled": true,

    // ── C/C++ Extension ────────────────────────────────────────────────
    "C_Cpp.default.compilerPath": "C:/Espressif/tools/xtensa-esp-elf/esp-15.2.0_20251204/xtensa-esp-elf/bin/xtensa-esp32-elf-gcc.exe",
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/components/**",
        "${workspaceFolder}/main",
        "C:/esp/v6.0.1/esp-idf/components/**"
    ],
    "C_Cpp.default.defines": [
        "ESP_PLATFORM",
        "IDF_VER=\"v6.0.1\"",
        "CONFIG_IDF_TARGET_ESP32=1"
    ],
    "C_Cpp.default.cStandard": "c11",
    "C_Cpp.default.intelliSenseMode": "gcc-x86",

    // ── File associations ───────────────────────────────────────────────
    "files.associations": {
        "*.h": "c",
        "Kconfig": "properties",
        "Kconfig.projbuild": "properties",
        "sdkconfig": "properties",
        "sdkconfig.defaults": "properties"
    },

    // ── Exclude build artifacts from search/explorer ───────────────────
    "files.exclude": {
        "**/build": true,
        "**/.git": true
    },
    "search.exclude": {
        "**/build": true,
        "**/node_modules": true
    },
    "idf.currentSetup": "C:\\esp\\v6.0.1\\esp-idf"
}
